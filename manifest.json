{
  "manifest_version": 3,
  "name": "RWeb Course2Cal",
  "version": "1.0.0",
  "description": "Extracts course information from RWeb and helps sync it to Google Calendar.",
  "permissions": [
    "activeTab",
    "scripting",
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://*.ucr.edu/*",
    "https://www.googleapis.com/*"
  ],
  "action": {
    "default_title": "Scrape Courses",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://registrationssb.ucr.edu/StudentRegistrationSsb/ssb/*"
      ],
      "js": [
        "content/content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "oauth2": {
    "client_id": "1066934690725-m8ct6i0th3u18ou0vu1444l2mnud9vnn.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.events"
    ]
  }
}
