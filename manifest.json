{
  "manifest_version": 3,
  "name": "Course2Cal for RWeb",
  "version": "1.1.0",
  "description": "Extracts course information from RWeb and syncs it to Google Calendar. This extension is not affiliated with or endorsed by UCR.",
  "permissions": [
    "activeTab",
    "scripting",
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://registrationssb.ucr.edu/*",
    "https://www.googleapis.com/*"
  ],
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_title": "Scrape Courses",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://registrationssb.ucr.edu/StudentRegistrationSsb/ssb/*"
      ],
      "js": [
        "content/content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "oauth2": {
    "client_id": "1066934690725-m8ct6i0th3u18ou0vu1444l2mnud9vnn.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.events"
    ]
  }
}
